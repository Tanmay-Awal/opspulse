generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id            String   @id @default(uuid())
  name          String
  domain        String   @unique
  webhookSecret String   @map("webhook_secret")
  plan          String   @default("free")
  createdAt     DateTime @default(now()) @map("created_at")

  users         User[]
  incidents     Incident[]
  onCallSchedules  OnCallSchedule[]
  escalationPolicies EscalationPolicy[] 

  @@map("organizations")
}

model User {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  email        String
  name         String
  role         String   @default("engineer")
  phoneNumber  String?  @map("phone_number")
  slackUserId  String?  @map("slack_user_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id])
  
  @@unique([orgId, email])
  @@map("users")
}

model Incident {
  id                  String    @id @default(uuid())
  orgId               String    @map("org_id")
  title               String
  status              String    @default("open")
  priority            String
  source              String
  eventType           String    @map("event_type")
  assignedTo          String?   @map("assigned_to")
  escalationLevel     Int       @default(0) @map("escalation_level")
  eventCount          Int       @default(1) @map("event_count")
  acknowledgedAt      DateTime? @map("acknowledged_at")
  acknowledgedBy      String?   @map("acknowledged_by")
  resolvedAt          DateTime? @map("resolved_at")
  resolvedBy          String?   @map("resolved_by")
  rootCauseCategory   String?   @map("root_cause_category")
  resolutionNotes     String?   @map("resolution_notes")
  metadata            Json?
  createdAt           DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id])

  @@index([orgId, status])
  @@index([orgId, createdAt])
  @@index([assignedTo, status])
  @@map("incidents")
}


model IncidentEvent {
  id          String   @id @default(uuid())
  incidentId  String   @map("incident_id")
  source      String
  eventType   String   @map("event_type")
  message     String
  severity    String?
  payload     Json
  receivedAt  DateTime @default(now()) @map("received_at")

  @@index([incidentId])
  @@map("incident_events")
}

model OnCallSchedule {
  id              String   @id @default(uuid())
  orgId           String   @map("org_id")
  teamName        String   @map("team_name")
  currentOnCallId String   @map("current_oncall_id")
  rotationType    String   @default("weekly") @map("rotation_type")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@map("on_call_schedules")
}
model EscalationPolicy {
  id        String   @id @default(uuid())
  orgId     String   @map("org_id")
  teamName  String   @map("team_name")
  levels    Json     // Array of {userId, waitMinutes}
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@map("escalation_policies")
}

model AuditLog {
  id         String   @id @default(uuid())
  incidentId String   @map("incident_id")
  action     String
  actorId    String?  @map("actor_id")
  actorEmail String?  @map("actor_email")
  fromValue  Json?    @map("from_value")
  toValue    Json?    @map("to_value")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  timestamp  DateTime @default(now())

  @@index([incidentId])
  @@index([timestamp])
  @@map("audit_logs")
}

model WebhookJob {
  id           String   @id @default(uuid())
  url          String
  payload      Json
  headers      Json?
  attempts     Int      @default(0)
  maxAttempts  Int      @default(6) @map("max_attempts")
  status       String   @default("pending")
  nextRetryAt  DateTime @default(now()) @map("next_retry_at")
  lastError    String?  @map("last_error")
  createdAt    DateTime @default(now()) @map("created_at")
  completedAt  DateTime? @map("completed_at")

  @@index([status, nextRetryAt])
  @@map("webhook_jobs")
}
